# ============================================
# 应用基础配置
# ============================================
NODE_ENV=development
APP_NAME=农光智助银青共富平台
APP_VERSION=1.0.0
APP_PORT=3000
APP_HOST=0.0.0.0

# ============================================
# ModelScope API配置（多模态大模型）
# ============================================
MODELSCOPE_API_KEY=your_api_key_here
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_TIMEOUT=30000

# 模型选择策略
MODELSCOPE_COMPLEX_MODEL=Qwen/Qwen3.5-122B-A10B
MODELSCOPE_SIMPLE_MODEL=Qwen/Qwen3-8B
MODELSCOPE_MAX_TOKENS=2000
MODELSCOPE_TEMPERATURE=0.7

# 成本控制
MODELSCOPE_DAILY_QUOTA=10000
MODELSCOPE_CACHE_TTL=86400
MODELSCOPE_ENABLE_CACHE=true

# ============================================
# 本地模型配置
# ============================================
LOCAL_MODELS_DIR=./models
LOCAL_MODELS_CACHE_DIR=./data/model_cache

# PaddleClas作物识别
PADDLECLAS_MODEL_PATH=./models/paddleclas/crop_recognition_v2.pdparams
PADDLECLAS_CONFIDENCE_THRESHOLD=0.75
PADDLECLAS_BATCH_SIZE=4

# YOLOv8遮阴检测
YOLOV8_MODEL_PATH=./models/yolov8/shade_detection.pt
YOLOV8_CONFIDENCE_THRESHOLD=0.6
YOLOV8_IOU_THRESHOLD=0.45
YOLOV8_IMAGE_SIZE=640

# 土壤健康分析
SOIL_MODEL_PATH=./models/soil-analysis/soil_health_v1.onnx
SOIL_COLOR_SPACE=LAB
SOIL_TEXTURE_FEATURES=true

# ============================================
# 数据库配置
# ============================================
SQLITE_DB_PATH=./data/database.sqlite
SQLITE_BACKUP_DIR=./data/backups
SQLITE_AUTO_BACKUP=true
SQLITE_BACKUP_INTERVAL=86400
SQLITE_MAX_BACKUPS=7

# ============================================
# JSON文件存储配置
# ============================================
JSON_CACHE_DIR=./data/cache
JSON_UPLOAD_DIR=./data/uploads
JSON_POLICY_DIR=./data/policies
JSON_KNOWLEDGE_DIR=./data/knowledge

# 缓存策略
JSON_CACHE_MAX_SIZE_MB=500
JSON_CACHE_CLEANUP_INTERVAL=3600
JSON_CACHE_DEFAULT_TTL=86400

# ============================================
# 外部API配置
# ============================================
# 和风天气API (QWeather) - 中国天气数据
# 注册地址: https://dev.qweather.com/
QWEATHER_API_KEY=your_qweather_api_key_here
QWEATHER_BASE_URL=https://devapi.qweather.com/v7
QWEATHER_TIMEOUT=10000
QWEATHER_CACHE_TTL=3600

# 默认位置（山东寿光）
DEFAULT_LOCATION=119.91,36.86
DEFAULT_CITY_ID=101121301

# Open-Meteo气象API（备用）
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1
OPENMETEO_TIMEOUT=10000
OPENMETEO_CACHE_TTL=3600

# Renewables.ninja光伏模拟
RENEWABLES_NINJA_TOKEN=optional_token_here
RENEWABLES_NINJA_BASE_URL=https://www.renewables.ninja/api

# 中国农科院数据集
CAAS_DATASET_PATH=./data/external/caas_agrivoltaic_2026.geojson

# ============================================
# 政策爬虫配置
# ============================================
POLICY_CRAWLER_ENABLED=true
POLICY_SOURCES=国家能源局,农业农村部,生态环境部
POLICY_UPDATE_INTERVAL=604800
POLICY_CRAWLER_USER_AGENT=Mozilla/5.0 (compatible; AgriBot/1.0)

# ============================================
# 四位一体功能开关
# ============================================
# 农业维度
FEATURE_CROP_LIFECYCLE=true
FEATURE_SOLAR_TERMS=true
FEATURE_TRADITIONAL_WISDOM=true

# 能源维度
FEATURE_PV_MONITORING=true
FEATURE_ENERGY_OPTIMIZATION=true
FEATURE_STORAGE_ADVICE=true

# 环境维度
FEATURE_SOIL_MONITORING=true
FEATURE_BIODIVERSITY=true
FEATURE_WATER_CYCLE=true

# 人文维度
FEATURE_WISDOM_INHERITANCE=true
FEATURE_FAMILY_COLLABORATION=true
FEATURE_CULTURE_MEMORY=true

# ============================================
# 中国政策环境适配
# ============================================
# 补贴计算
SUBSIDY_PROVINCE=北京
SUBSIDY_POLICY_VERSION=2026
SUBSIDY_PV_RATE=0.03
SUBSIDY_ORGANIC_CERT_BONUS=5000

# 碳普惠对接
CARBON_CREDIT_PLATFORM=北京绿色生活碳普惠
CARBON_PRICE_PER_TON=50
CARBON_REPORT_FORMAT=PDF

# 认证报告
CERT_TEMPLATE_DIR=./data/templates
CERT_OUTPUT_DIR=./data/reports
CERT_WATERMARK=true

# ============================================
# 弱网优化配置
# ============================================
NETWORK_MODE=4G
IMAGE_COMPRESSION_QUALITY=0.7
IMAGE_MAX_SIZE_KB=500
OFFLINE_MODE_ENABLED=true
PREFETCH_ENABLED=true

# ============================================
# 安全与合规
# ============================================
# 数据安全
DATA_ENCRYPTION_ENABLED=true
DATA_ENCRYPTION_KEY=your_32_char_encryption_key_here
PII_MASKING_ENABLED=true

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE_MB=50
LOG_MAX_FILES=10

# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# 适老化配置
# ============================================
ACCESSIBILITY_FONT_SIZE_MIN=18
ACCESSIBILITY_CONTRAST_RATIO=4.5
ACCESSIBILITY_VOICE_SPEED=0.8
ACCESSIBILITY_DIALECT_SUPPORT=true

# ============================================
# 开发调试
# ============================================
DEBUG_MODE=false
DEBUG_LOG_SQL=false
DEBUG_LOG_API_CALLS=false
DEBUG_MOCK_EXTERNAL_API=false
